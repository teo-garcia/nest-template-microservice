# Service
SERVICE_NAME=nest-template-microservice

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
SHUTDOWN_TIMEOUT=10000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_microservice?schema=public

# NATS JetStream
NATS_URL=nats://localhost:4222
NATS_CLIENT_NAME=nest-template-microservice
NATS_SUBJECT_PREFIX=templates
NATS_STREAM_PREFIX=template
NATS_TIMEOUT=5000
NATS_ACK_WAIT_SECONDS=30
NATS_MAX_MESSAGES=10000
NATS_MAX_RECONNECT_ATTEMPTS=10
NATS_RECONNECT_TIME_WAIT=2000

# Redis (cache/rate limiting/jobs/idempotency)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=micro:

# Logging
LOG_LEVEL=info
ENABLE_CONSOLE_LOGS=true

# Metrics
METRICS_ENABLED=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3000
