SERVICE_NAME=microservice
NODE_ENV=test
PORT=3001
API_PREFIX=api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_microservice_test?schema=public
DATABASE_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_CLIENT_NAME=nest-template-microservice-test
NATS_SUBJECT_PREFIX=templates
NATS_STREAM_PREFIX=template
NATS_TIMEOUT=5000
NATS_ACK_WAIT_SECONDS=30
NATS_MAX_MESSAGES=1000
NATS_MAX_RECONNECT_ATTEMPTS=1
NATS_RECONNECT_TIME_WAIT=1000
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=micro:test:
LOG_LEVEL=warn
ENABLE_CONSOLE_LOGS=false
METRICS_ENABLED=false
CORS_ORIGIN=
